<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Shared Gallery Widget</title>
    <style>
        /* CSS Variables for Apple-style Light Theme */
        :root {
            --bg-color: #f5f5f7;
            --text-primary: #1d1d1f;
            --text-secondary: #86868b;
            --card-bg: rgba(255, 255, 255, 0.7);
            --glass-border: 1px solid rgba(255, 255, 255, 0.5);
            --accent-color: #0071e3;
            --accent-hover: #0077ED;
            --shadow: 0 10px 30px rgba(0, 0, 0, 0.08);
            --radius-lg: 24px;
            --radius-md: 14px;
            --transition: all 0.3s cubic-bezier(0.25, 0.8, 0.25, 1);
        }

        /* Typography & Base Setup */
        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
        }

        body {
            font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
            background-color: var(--bg-color);
            color: var(--text-primary);
            -webkit-font-smoothing: antialiased;
            padding: 40px 20px;
            display: flex;
            flex-direction: column;
            align-items: center;
        }

        .widget-container {
            width: 100%;
            max-width: 900px;
        }

        header {
            text-align: center;
            margin-bottom: 40px;
        }

        header h1 {
            font-size: 40px;
            font-weight: 700;
            letter-spacing: -0.015em;
            margin-bottom: 8px;
        }

        header p {
            font-size: 19px;
            color: var(--text-secondary);
            font-weight: 400;
        }

        /* Glassmorphism Upload Section */
        .upload-section {
            background: var(--card-bg);
            backdrop-filter: saturate(180%) blur(20px);
            -webkit-backdrop-filter: saturate(180%) blur(20px);
            border: var(--glass-border);
            border-radius: var(--radius-lg);
            padding: 30px;
            box-shadow: var(--shadow);
            margin-bottom: 50px;
            display: flex;
            flex-direction: column;
            gap: 20px;
        }

        .input-group {
            display: flex;
            flex-direction: column;
            gap: 8px;
        }

        .input-group label {
            font-size: 14px;
            font-weight: 600;
            color: var(--text-secondary);
        }

        input[type="text"], input[type="file"] {
            width: 100%;
            padding: 16px;
            border-radius: var(--radius-md);
            border: 1px solid rgba(0,0,0,0.1);
            background: rgba(255,255,255,0.8);
            font-size: 16px;
            font-family: inherit;
            transition: var(--transition);
        }

        input[type="text"]:focus {
            outline: none;
            border-color: var(--accent-color);
            box-shadow: 0 0 0 4px rgba(0, 113, 227, 0.2);
        }

        input[type="file"]::file-selector-button {
            background-color: var(--bg-color);
            border: 1px solid rgba(0,0,0,0.1);
            border-radius: 8px;
            padding: 8px 16px;
            margin-right: 16px;
            cursor: pointer;
            font-weight: 500;
            transition: var(--transition);
        }

        input[type="file"]::file-selector-button:hover {
            background-color: #e8e8ed;
        }

        .btn-submit {
            background-color: var(--accent-color);
            color: white;
            border: none;
            padding: 16px 24px;
            border-radius: 980px; /* Apple pill shape */
            font-size: 17px;
            font-weight: 600;
            cursor: pointer;
            transition: var(--transition);
            align-self: flex-end;
        }

        .btn-submit:hover {
            background-color: var(--accent-hover);
            transform: scale(1.02);
        }

        .btn-submit:active {
            transform: scale(0.98);
        }

        /* Gallery Grid */
        .gallery-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
            gap: 24px;
        }

        /* Individual Photo Card */
        .card {
            background: var(--card-bg);
            backdrop-filter: saturate(180%) blur(20px);
            -webkit-backdrop-filter: saturate(180%) blur(20px);
            border: var(--glass-border);
            border-radius: var(--radius-lg);
            overflow: hidden;
            box-shadow: var(--shadow);
            transition: var(--transition);
            cursor: pointer;
            opacity: 0;
            transform: translateY(20px);
            animation: fadeInCard 0.6s ease forwards;
        }

        .card:hover {
            transform: translateY(-5px) scale(1.01);
            box-shadow: 0 14px 40px rgba(0, 0, 0, 0.12);
        }

        .card-image {
            width: 100%;
            height: 220px;
            object-fit: cover;
            background-color: #e8e8ed;
        }

        .card-content {
            padding: 20px;
        }

        .card-title {
            font-size: 20px;
            font-weight: 600;
            margin-bottom: 4px;
            letter-spacing: -0.01em;
        }

        .card-date {
            font-size: 14px;
            color: var(--text-secondary);
        }

        /* Animations */
        @keyframes fadeInCard {
            to {
                opacity: 1;
                transform: translateY(0);
            }
        }
    </style>
</head>
<body>

    <div class="widget-container">
        <header>
            <h1>Shared Moments</h1>
            <p>Upload and share your photos with everyone.</p>
        </header>

        <div class="upload-section">
            <div class="input-group">
                <label for="photoTitle">Card Title</label>
                <input type="text" id="photoTitle" placeholder="E.g., Trip to the Mountains..." required>
            </div>
            
            <div class="input-group">
                <label for="photoFile">Select Photo</label>
                <input type="file" id="photoFile" accept="image/*" required>
            </div>

            <button class="btn-submit" onclick="handleUpload()">Share Photo</button>
        </div>

        <div class="gallery-grid" id="galleryGrid">
            </div>
    </div>

    <script>
        // Array to hold our local state for demonstration purposes
        const cardsData = [];

        function handleUpload() {
            const titleInput = document.getElementById('photoTitle');
            const fileInput = document.getElementById('photoFile');

            const title = titleInput.value.trim();
            const file = fileInput.files[0];

            // Basic validation
            if (!title) {
                alert("Please provide a title for your card.");
                return;
            }
            if (!file) {
                alert("Please select a photo to upload.");
                return;
            }

            // Read the file as a Data URL so we can display it immediately
            const reader = new FileReader();
            reader.onload = function(e) {
                const imageUrl = e.target.result;
                
                // Create a data object
                const newCard = {
                    id: Date.now(),
                    title: title,
                    imageUrl: imageUrl,
                    date: new Date().toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' })
                };

                // Add to our state array and re-render
                cardsData.unshift(newCard); // unshift adds to the beginning of the array
                renderGallery();

                // Reset inputs
                titleInput.value = '';
                fileInput.value = '';
            };

            reader.readAsDataURL(file);
        }

        function renderGallery() {
            const galleryGrid = document.getElementById('galleryGrid');
            galleryGrid.innerHTML = ''; // Clear current grid

            cardsData.forEach(card => {
                // Create card container
                const cardElement = document.createElement('div');
                cardElement.className = 'card';

                // Inject HTML structure for the card
                cardElement.innerHTML = `
                    <img src="${card.imageUrl}" alt="${card.title}" class="card-image">
                    <div class="card-content">
                        <h3 class="card-title">${card.title}</h3>
                        <span class="card-date">${card.date}</span>
                    </div>
                `;

                galleryGrid.appendChild(cardElement);
            });
        }
    </script>
</body>
</html>
